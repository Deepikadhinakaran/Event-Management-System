package com.eventmanagement.servlets;

import java.io.IOException;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

@WebServlet("/register")
public class RegisterEventServlet extends HttpServlet {
    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {
        String eventType = request.getParameter("event-type");
        String eventDate = request.getParameter("event-date");
        String startTime = request.getParameter("event-start-time");
        String endTime = request.getParameter("event-end-time");
        String venue = request.getParameter("event-venue");
        String yearOfStudy = request.getParameter("year-of-study");
        String section = request.getParameter("section");
        String guestPerson = request.getParameter("guest-person");
        String guestDesignation = request.getParameter("guest-designation");
        String guestAddress = request.getParameter("guest-address");
        String topic = request.getParameter("topic");
        String description = request.getParameter("event-description");

        try {
            Class.forName("com.mysql.jdbc.Driver");
            Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/event_management", "root", "password");

            String query = "INSERT INTO events (event_type, event_date, start_time, end_time, venue, year_of_study, section, guest_person, guest_designation, guest_address, topic, description, status) "
                    + "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'Pending')";
            PreparedStatement pstmt = conn.prepareStatement(query);
            pstmt.setString(1, eventType);
            pstmt.setString(2, eventDate);
            pstmt.setString(3, startTime);
            pstmt.setString(4, endTime);
            pstmt.setString(5, venue);
            pstmt.setInt(6, Integer.parseInt(yearOfStudy));
            pstmt.setString(7, section);
            pstmt.setString(8, guestPerson);
            pstmt.setString(9, guestDesignation);
            pstmt.setString(10, guestAddress);
            pstmt.setString(11, topic);
            pstmt.setString(12, description);
            pstmt.executeUpdate();

            pstmt.close();
            conn.close();
        } catch (Exception e) {
            e.printStackTrace();
        }

        response.sendRedirect("registration-success.jsp");
    }
}
